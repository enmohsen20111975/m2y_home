// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// توصيات الخبراء
model ExpertRecommendation {
  id                    String    @id @default(cuid())
  stock_symbol          String
  stock_name_ar         String?
  expert_name           String
  expert_source         String?   @default("manual")
  action                String    @default("BUY")     // BUY, SELL, HOLD
  entry_price           Float?
  target_price          Float?
  stop_loss             Float?
  recommendation_date   DateTime  @default(now())
  expected_duration     String?
  expected_duration_days Int?
  status                String    @default("PENDING") // PENDING, ACTIVE, HIT_TARGET, STOPPED, CLOSED
  final_price           Float?
  profit_loss_percent   Float?
  hit_target            Boolean?  @default(false)
  hit_stop_loss         Boolean?  @default(false)
  result_notes          String?
  notes                 String?
  verified_at           DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  @@index([expert_name])
  @@index([stock_symbol])
  @@index([status])
  @@index([recommendation_date])
}

// سجل خبراء التوصيات
model ExpertTrackRecord {
  id                      String    @id @default(cuid())
  expert_name             String    @unique
  total_recommendations   Int       @default(0)
  successful_recommendations Int    @default(0)
  failed_recommendations  Int       @default(0)
  success_rate            Float     @default(0)
  avg_return              Float?
  last_recommendation     DateTime?
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  @@index([expert_name])
  @@index([success_rate])
}